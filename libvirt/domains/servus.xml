<!-- servus : client OpenWrt branché derrière custos.
     NICs (l'ordre fixe la numérotation eth0..eth1) :
       eth0 = homelab-lan    (DHCP fourni par via via le pont custos)
       eth1 = homelab-mgmt   (DHCP, SSH depuis l'hôte)
-->
<domain type='kvm'>
  <name>homelab-servus</name>
  <memory unit='MiB'>128</memory>
  <vcpu>1</vcpu>
  <cpu mode='host-passthrough' check='none'/>
  <os>
    <type arch='x86_64'>hvm</type>
    <boot dev='hd'/>
  </os>
  <features>
    <acpi/>
  </features>
  <devices>
    <disk type='file' device='disk'>
      <source file='/var/lib/libvirt/images/homelab-servus.qcow2'/>
      <driver name='qemu' type='qcow2'/>
      <target dev='vda' bus='virtio'/>
    </disk>
    <interface type='network'>
      <mac address='52:54:00:fe:03:01'/>
      <source network='homelab-lan'/>
      <model type='virtio'/>
    </interface>
    <interface type='network'>
      <mac address='52:54:00:fe:03:02'/>
      <source network='homelab-mgmt'/>
      <model type='virtio'/>
    </interface>
    <serial type='file'>
      <source path='/tmp/homelab-servus-serial.log' append='on'/>
      <target type='isa-serial' port='0'/>
    </serial>
    <console type='file'>
      <source path='/tmp/homelab-servus-serial.log' append='on'/>
      <target type='serial' port='0'/>
    </console>
  </devices>
</domain>
