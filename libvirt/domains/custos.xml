<!-- custos : pont L2 transparent entre homelab-up (côté via) et homelab-lan (côté servus).
     NICs (l'ordre fixe la numérotation eth0..eth2) :
       eth0 = homelab-up     (esclave de br-lan, côté routeur)
       eth1 = homelab-lan    (esclave de br-lan, côté client)
       eth2 = homelab-mgmt   (DHCP, SSH depuis l'hôte)
-->
<domain type='kvm'>
  <name>homelab-custos</name>
  <memory unit='MiB'>512</memory>
  <vcpu>2</vcpu>
  <cpu mode='host-passthrough' check='none'/>
  <os>
    <type arch='x86_64'>hvm</type>
    <boot dev='hd'/>
  </os>
  <features>
    <acpi/>
  </features>
  <devices>
    <disk type='file' device='disk'>
      <source file='/var/lib/libvirt/images/homelab-custos.qcow2'/>
      <driver name='qemu' type='qcow2'/>
      <target dev='vda' bus='virtio'/>
    </disk>
    <interface type='network'>
      <mac address='52:54:00:fe:02:01'/>
      <source network='homelab-up'/>
      <model type='virtio'/>
    </interface>
    <interface type='network'>
      <mac address='52:54:00:fe:02:02'/>
      <source network='homelab-lan'/>
      <model type='virtio'/>
    </interface>
    <interface type='network'>
      <mac address='52:54:00:fe:02:03'/>
      <source network='homelab-mgmt'/>
      <model type='virtio'/>
    </interface>
    <serial type='file'>
      <source path='/tmp/homelab-custos-serial.log' append='on'/>
      <target type='isa-serial' port='0'/>
    </serial>
    <console type='file'>
      <source path='/tmp/homelab-custos-serial.log' append='on'/>
      <target type='serial' port='0'/>
    </console>
  </devices>
</domain>
