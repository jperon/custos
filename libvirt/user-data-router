#cloud-config
users:
  - name: debian
    sudo: ALL=(ALL) NOPASSWD:ALL
    ssh_authorized_keys:
      - ssh-rsa  jacques@peron
    groups: [sudo]
    shell: /bin/bash
packages:
  - qemu-guest-agent
  - nftables
  - iproute2
runcmd:
  - systemctl enable --now qemu-guest-agent
  # ip_forward + masquerade for clients routed through the filter bridge
  - echo 'net.ipv4.ip_forward=1' >> /etc/sysctl.d/90-custos.conf
  - sysctl -p /etc/sysctl.d/90-custos.conf
  - |
    # Find WAN interface by MAC and set up masquerade
    WAN=$(for d in /sys/class/net/*/; do
      [ "$(cat ${d}address 2>/dev/null)" = "52:54:00:00:02:02" ] && basename "$d"
    done)
    if [ -n "$WAN" ]; then
      nft add table ip nat
      nft 'add chain ip nat postrouting { type nat hook postrouting priority 100; }'
      nft add rule ip nat postrouting oifname "$WAN" masquerade
      nft list ruleset > /etc/nftables.conf
      systemctl enable --now nftables
    fi
