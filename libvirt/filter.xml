<!-- CustosVirginum filter — OpenWrt VM for E2E tests -->
<!-- NICs (order matters, matches /etc/config/network):
       eth0 = custos-lan    (bridged into br-lan, client side)
       eth1 = custos-up     (bridged into br-lan, dns-server side)
       eth2 = custos-mgmt   (DHCP, SSH access from host)
-->
<domain type='kvm'>
  <name>custos-filter</name>
  <memory unit='MiB'>1024</memory>
  <vcpu>2</vcpu>
  <cpu mode='host-passthrough' check='none'/>
  <os>
    <type arch='x86_64'>hvm</type>
    <boot dev='hd'/>
  </os>
  <features>
    <acpi/>
  </features>
  <devices>
    <disk type='file' device='disk'>
      <source file='/var/lib/libvirt/images/custos-filter.qcow2'/>
      <driver name='qemu' type='qcow2'/>
      <target dev='vda' bus='virtio'/>
    </disk>
    <interface type='network'>
      <mac address='52:54:00:00:01:01'/>
      <source network='custos-lan'/>
      <model type='virtio'/>
    </interface>
    <interface type='network'>
      <mac address='52:54:00:00:01:02'/>
      <source network='custos-up'/>
      <model type='virtio'/>
    </interface>
    <interface type='network'>
      <mac address='52:54:00:00:01:03'/>
      <source network='custos-mgmt'/>
      <model type='virtio'/>
    </interface>
    <serial type='file'>
      <source path='/tmp/custos-filter-serial.log' append='on'/>
      <target type='isa-serial' port='0'/>
    </serial>
    <console type='file'>
      <source path='/tmp/custos-filter-serial.log' append='on'/>
      <target type='serial' port='0'/>
    </console>
  </devices>
</domain>
