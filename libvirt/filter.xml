<!-- CustosVirginum DNS Filter — VM definition for KVM/libvirt tests -->
<domain type='kvm'>
  <name>custos-filter</name>
  <memory unit='MiB'>1024</memory>
  <vcpu>2</vcpu>
  <cpu mode='host-passthrough' check='none'/>
  <os>
    <type arch='x86_64'>hvm</type>
    <kernel>/tmp/custos-vmlinuz</kernel>
    <initrd>/tmp/custos-initrd.img</initrd>
    <cmdline>root=/dev/vda1 ro console=ttyS0,115200 earlyprintk=ttyS0,115200 consoleblank=0</cmdline>
  </os>
  <features>
    <acpi/>
  </features>
  <devices>
    <disk type='file' device='disk'>
      <source file='/var/lib/libvirt/images/custos-filter.qcow2'/>
      <driver name='qemu' type='qcow2'/>
      <target dev='vda' bus='virtio'/>
    </disk>
    <disk type='file' device='cdrom'>
      <source file='/var/lib/libvirt/images/cidata-filter.iso'/>
      <driver name='qemu' type='raw'/>
      <target dev='sda' bus='sata'/>
      <readonly/>
    </disk>
    <interface type='network'>
      <mac address='52:54:00:00:01:01'/>
      <source network='wanfilter'/>
      <model type='virtio'/>
    </interface>
    <interface type='network'>
      <mac address='52:54:00:00:01:02'/>
      <source network='lan'/>
      <model type='virtio'/>
    </interface>
    <interface type='network'>
      <mac address='52:54:00:00:01:03'/>
      <source network='wan'/>
      <model type='virtio'/>
    </interface>
    <serial type='file'>
      <source path='/tmp/custos-filter-serial.log' append='on'/>
      <target type='isa-serial' port='0'/>
    </serial>
    <console type='file'>
      <source path='/tmp/custos-filter-serial.log' append='on'/>
      <target type='serial' port='0'/>
    </console>
    <channel type='unix'>
      <target type='virtio' name='org.qemu.guest_agent.0'/>
    </channel>
  </devices>
</domain>
