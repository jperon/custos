version: 2
ethernets:
  # WAN side of the bridge (toward router VM) — no IP, bridged into br0
  wanside:
    match:
      macaddress: "52:54:00:00:01:01"
    dhcp4: false
  # LAN side of the bridge (toward client VM) — no IP, bridged into br0
  lanside:
    match:
      macaddress: "52:54:00:00:01:02"
    dhcp4: false
  # Management interface: DHCP from wan network (192.168.200.x), SSH access
  mgmt:
    match:
      macaddress: "52:54:00:00:01:03"
    dhcp4: true
bridges:
  br0:
    interfaces: [wanside, lanside]
    dhcp4: false
    # Minimal forwarding delay so bridge comes up fast
    parameters:
      stp: false
      forward-delay: 0
    # Provide a host address so the kernel can route REFUSED packets to LAN clients
    addresses: [10.99.0.254/24]
