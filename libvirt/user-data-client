#cloud-config
users:
  - name: debian
    sudo: ALL=(ALL) NOPASSWD:ALL
    ssh_authorized_keys:
      - ssh-rsa  jacques@peron
    groups: [sudo]
    shell: /bin/bash
packages:
  - qemu-guest-agent
  - bind9-dnsutils
  - iputils-ping
  - curl
  - netcat-openbsd
write_files:
  # Static entries for blocked targets. Custos forges NXDOMAIN/REFUSED for
  # these domains, so curl would fail at DNS resolution and never emit a
  # SYN to trigger Q2 (captive) or Q3 (reject). /etc/hosts lets us bypass
  # resolution and exercise the TCP path directly.
  - path: /etc/hosts.custos
    content: |
      10.99.0.60 blocked.test
      10.99.0.70 tracker.test
runcmd:
  - systemctl enable --now qemu-guest-agent
  - sh -c 'cat /etc/hosts.custos >> /etc/hosts'
