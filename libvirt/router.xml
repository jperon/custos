<!-- CustosVirginum DNS Router — Debian VM for KVM/libvirt tests -->
<!-- Provides IP forwarding + masquerade between wanfilter and wan networks. -->
<domain type='kvm'>
  <name>custos-router</name>
  <memory unit='MiB'>512</memory>
  <vcpu>1</vcpu>
  <cpu mode='host-passthrough' check='none'/>
  <os>
    <type arch='x86_64'>hvm</type>
    <kernel>/tmp/custos-vmlinuz</kernel>
    <initrd>/tmp/custos-initrd.img</initrd>
    <cmdline>root=/dev/vda1 ro console=ttyS0,115200 earlyprintk=ttyS0,115200 consoleblank=0</cmdline>
  </os>
  <features>
    <acpi/>
  </features>
  <devices>
    <disk type='file' device='disk'>
      <source file='/var/lib/libvirt/images/custos-router.qcow2'/>
      <driver name='qemu' type='qcow2'/>
      <target dev='vda' bus='virtio'/>
    </disk>
    <disk type='file' device='cdrom'>
      <source file='/var/lib/libvirt/images/cidata-router.iso'/>
      <driver name='qemu' type='raw'/>
      <target dev='sda' bus='sata'/>
      <readonly/>
    </disk>
    <!-- LAN side: static 10.99.0.1/24, gateway for client via filter bridge -->
    <interface type='network'>
      <mac address='52:54:00:00:02:01'/>
      <source network='wanfilter'/>
      <model type='virtio'/>
    </interface>
    <!-- WAN side: DHCP on wan NAT network (192.168.200.x) -->
    <interface type='network'>
      <mac address='52:54:00:00:02:02'/>
      <source network='wan'/>
      <model type='virtio'/>
    </interface>
    <serial type='file'>
      <source path='/tmp/custos-router-serial.log' append='on'/>
      <target type='isa-serial' port='0'/>
    </serial>
    <console type='file'>
      <source path='/tmp/custos-router-serial.log' append='on'/>
      <target type='serial' port='0'/>
    </console>
    <channel type='unix'>
      <target type='virtio' name='org.qemu.guest_agent.0'/>
    </channel>
  </devices>
</domain>
