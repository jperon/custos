config interface 'loopback'
	option device 'lo'
	option proto 'static'
	option ipaddr '127.0.0.1'
	option netmask '255.0.0.0'

config globals 'globals'
	option ula_prefix 'fd99::/48'

# Transparent bridge between client and upstream (DNS server).
# eth0 = custos-lan (client side), eth1 = custos-up (DNS server side).
config device
	option name 'br-lan'
	option type 'bridge'
	list ports 'eth0'
	list ports 'eth1'

config interface 'lan'
	option device 'br-lan'
	option proto 'static'
	option ipaddr '10.99.0.254'
	option netmask '255.255.255.0'
	# No default gateway: self-contained test env.

# Management NIC, DHCP from the custos-mgmt libvirt network (192.168.200.0/24).
config interface 'mgmt'
	option device 'eth2'
	option proto 'dhcp'
