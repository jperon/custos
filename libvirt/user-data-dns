#cloud-config
users:
  - name: debian
    sudo: ALL=(ALL) NOPASSWD:ALL
    ssh_authorized_keys:
      - ssh-rsa  jacques@peron
    groups: [sudo]
    shell: /bin/bash
packages:
  - qemu-guest-agent
  - dnsmasq
  - nginx-light
  - openssl
write_files:
  # dnsmasq: fake zones for the E2E tests.
  - path: /etc/dnsmasq.d/custos-test.conf
    content: |
      port=53
      listen-address=10.99.0.1
      listen-address=127.0.0.1
      no-resolv
      domain-needed
      bogus-priv
      log-queries
      # Fake records used by the E2E suite. Addresses are served by nginx
      # via IP aliases on this same VM.
      address=/allowed.test/10.99.0.50
      address=/mail.allowed.test/10.99.0.50
      address=/blocked.test/10.99.0.60
      address=/tracker.test/10.99.0.70
  # nginx: one virtual host per target IP.
  - path: /etc/nginx/sites-available/custos-test
    content: |
      server {
        listen 10.99.0.50:80 default_server;
        server_name allowed.test mail.allowed.test;
        location / { add_header Content-Type text/plain; return 200 "allowed\n"; }
      }
      server {
        listen 10.99.0.60:80;
        server_name blocked.test;
        location / { add_header Content-Type text/plain; return 200 "blocked-target\n"; }
      }
      server {
        listen 10.99.0.70:443 ssl;
        server_name tracker.test;
        ssl_certificate     /etc/nginx/custos-test.crt;
        ssl_certificate_key /etc/nginx/custos-test.key;
        location / { add_header Content-Type text/plain; return 200 "tracker-target\n"; }
      }
  # Self-signed cert for the HTTPS target.
  - path: /usr/local/sbin/custos-gen-cert.sh
    permissions: '0755'
    content: |
      #!/bin/sh
      set -e
      CRT=/etc/nginx/custos-test.crt
      KEY=/etc/nginx/custos-test.key
      [ -f "$CRT" ] && exit 0
      openssl req -x509 -nodes -newkey rsa:2048 -days 3650 \
        -subj "/CN=tracker.test" \
        -keyout "$KEY" -out "$CRT" >/dev/null 2>&1
  # IP aliases and bridge-friendly sysctls.
  - path: /etc/systemd/system/custos-aliases.service
    content: |
      [Unit]
      Description=IP aliases for custos E2E targets
      After=network-online.target
      Wants=network-online.target
      [Service]
      Type=oneshot
      RemainAfterExit=yes
      ExecStart=/bin/sh -c '\
        ip addr replace 10.99.0.50/24 dev eth0 && \
        ip addr replace 10.99.0.60/24 dev eth0 && \
        ip addr replace 10.99.0.70/24 dev eth0 \
      '
      [Install]
      WantedBy=multi-user.target
runcmd:
  - systemctl enable --now qemu-guest-agent
  - /usr/local/sbin/custos-gen-cert.sh
  - ln -sf /etc/nginx/sites-available/custos-test /etc/nginx/sites-enabled/custos-test
  - rm -f /etc/nginx/sites-enabled/default
  - systemctl enable --now custos-aliases.service
  - systemctl restart nginx
  - systemctl disable --now systemd-resolved || true
  - systemctl enable --now dnsmasq
