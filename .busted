-- .busted — configuration du runner Busted pour CustosVirginum
-- Chargé automatiquement depuis le répertoire courant (make test / make coverage).
--
-- Clés reconnues = noms longs des options CLI busted 2.x (sans "--").
-- Surcharges possibles sur la ligne de commande :
--   busted --tags=ffi          → uniquement les tests #ffi
--   busted --exclude-tags=ffi  → exclut les tests #ffi
--   busted -c                  → active luacov (--coverage)

return {
  -- Paramètres appliqués à toutes les configurations (-r)
  _all = {
    -- Ne charger que les .lua compilés (les .moon sources restent dans le repo
    -- mais ne doivent pas être exécutés deux fois).
    loaders  = "lua",
    -- Pattern de fichiers de spec
    pattern  = "_spec",
    verbose  = true,
    output   = "utfTerminal",
    -- Forcer LuaJIT (ffi requis)
    lua      = "luajit",
  },

  -- Configuration par défaut
  default = {
    -- Helper chargé avant chaque spec : injecte stubs ffi_defs, config, log.
    helper = "tests/helpers/busted_setup.lua",
  },
}
