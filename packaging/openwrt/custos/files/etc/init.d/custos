#!/bin/sh /etc/rc.common

USE_PROCD=1
START=95
STOP=05

LUAJIT=$(command -v luajit 2>/dev/null || command -v luajit2 2>/dev/null)
PROG=/usr/bin/custos
CUSTOS_DIR=/usr/share/custos
FILTER_CONFIG=/etc/custos/filter.yml
CRONTABS_ROOT=/etc/crontabs/root
CUSTOS_CRON_MARKER="# custos-update-lists"

start_service() {
    [ "$(uci get custos.main.enabled 2>/dev/null)" = "0" ] && return 0
    [ -z "$LUAJIT" ] && { echo "custos: luajit introuvable"; return 1; }

    # Crée un symlink /usr/bin/custos → luajit{,2} pour que procd utilise
    # "custos" comme ident syslog (procd extrait basename(command[0])).
    [ -L "$PROG" ] || ln -sf "$LUAJIT" "$PROG"

    # Génère /var/run/custos/config.lua depuis /etc/config/custos.
    # En cas d'échec, custos utilise le config.lua compilé dans CUSTOS_DIR.
    "$PROG" "$CUSTOS_DIR/uci_config.lua" || \
        echo "custos: avertissement — génération config UCI échouée, utilise les défauts compilés"

    # Applique le ruleset nftables (règles principales + extra UCI) depuis Lua
    # synchronement avant que procd ne démarre le worker.
    if ! _apply_lua_nft_rules; then
        echo "custos: avertissement — échec de l'application des règles nftables, démarrage en mode dégradé"
    fi

    procd_open_instance
    procd_set_param command "$PROG" "$CUSTOS_DIR/main.lua"
    procd_set_param env LUA_PATH="/usr/share/lua/?.lua;/usr/share/lua/?/init.lua;/usr/share/lua/5.1/?.lua;/usr/share/lua/5.1/?/init.lua;/usr/lib/lua/?.lua;/usr/lib/lua/?/init.lua;/usr/lib/lua/5.1/?.lua;/usr/lib/lua/5.1/?/init.lua;/var/run/custos/?.lua;$CUSTOS_DIR/?.lua;$CUSTOS_DIR/?/init.lua;;" LUA_CPATH="/usr/lib/lua/?.so;/usr/lib/lua/5.1/?.so;;" CUSTOS_FILTER_CONFIG="$FILTER_CONFIG"
    procd_set_param respawn 3600 5 5
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance

    # Planifie la mise à jour automatique des listes si activée
    if [ "$(uci get custos.main.update_lists_enabled 2>/dev/null)" != "0" ]; then
        _cron_add
    else
        _cron_remove
    fi
}

stop_service() {
    # Tuer explicitement les processus main.lua (couvre le cas où ils ont été
    # démarrés hors de procd, p.ex. par la suite de tests).
    _kill_workers

    # Nettoyer les règles nftables une fois les workers arrêtés.
    # Sinon les workers encore actifs peuvent tenter des opérations nft
    # sur une table déjà supprimée, ce qui spamme les logs de WARN.
    _cleanup_nft_rules

    # Supprimer le cron pour les mises à jour de listes
    _cron_remove
}

# Un rechargement applique tous les paramètres UCI : redémarrage complet nécessaire
# car les valeurs de config.lua sont capturées à l'initialisation des modules Lua.
reload_service() {
    stop
    start
}

# Rechargement automatique quand `uci commit custos` est exécuté.
service_triggers() {
    procd_add_reload_trigger "custos"
}

# ── Mise à jour des listes de domaines ───────────────────────────

update_lists() {
    [ -z "$LUAJIT" ] && { echo "custos: luajit introuvable"; return 1; }

    local config pid_file
    config=$(uci get custos.main.filter_config 2>/dev/null)
    config="${config:-$FILTER_CONFIG}"
    pid_file=/var/run/custos.pid

    echo "custos: mise à jour des listes de domaines (config: $config)..."
    "$PROG" "$CUSTOS_DIR/filter/updater.lua" \
        --config "$config" \
        --pid "$pid_file"
}

# ── Gestion du cron ──────────────────────────────────────────────

_cron_add() {
    local schedule config
    schedule=$(uci get custos.main.update_lists_schedule 2>/dev/null)
    schedule="${schedule:-0 3 * * *}"
    config=$(uci get custos.main.filter_config 2>/dev/null)
    config="${config:-$FILTER_CONFIG}"

    _cron_remove
    mkdir -p "$(dirname "$CRONTABS_ROOT")"
    touch "$CRONTABS_ROOT"
    printf '%s %s %s/filter/updater.lua --config %s --pid /var/run/custos.pid %s\n' \
        "$schedule" "$PROG" "$CUSTOS_DIR" "$config" "$CUSTOS_CRON_MARKER" \
        >> "$CRONTABS_ROOT"
    /etc/init.d/cron reload 2>/dev/null || true
}

_cron_remove() {
    [ -f "$CRONTABS_ROOT" ] || return 0
    sed -i "/$CUSTOS_CRON_MARKER/d" "$CRONTABS_ROOT"
    /etc/init.d/cron reload 2>/dev/null || true
}

# ── Règles nftables ───────────────────────────────────────────────────────────

# Applique le ruleset nftables principal (via nft_rules.apply()) et les règles
# nft extra UCI (via nft_extra_rules.apply_from_config()) en un seul appel Lua.
# Appelé depuis start_service() avant que procd ne démarre le worker.
_apply_lua_nft_rules() {
    LUA_PATH="/usr/share/lua/?.lua;/usr/share/lua/?/init.lua;/usr/share/lua/5.1/?.lua;/usr/share/lua/5.1/?/init.lua;/usr/lib/lua/?.lua;/usr/lib/lua/?/init.lua;/usr/lib/lua/5.1/?.lua;/usr/lib/lua/5.1/?/init.lua;/var/run/custos/?.lua;$CUSTOS_DIR/?.lua;$CUSTOS_DIR/?/init.lua;;" \
    LUA_CPATH="/usr/lib/lua/?.so;/usr/lib/lua/5.1/?.so;;" \
    CUSTOS_FILTER_CONFIG="$FILTER_CONFIG" \
        "$PROG" -e "if not require('nft_rules').apply() then os.exit(1) end; require('nft_extra_rules').apply_from_config()" \
        2>/dev/null
}

# ── Arrêt des workers ─────────────────────────────────────────────────────────
# Envoie SIGTERM aux processus main.lua ; les workers enfants s'arrêtent par
# propagation (shutdown_workers dans main.lua) ou par PR_SET_PDEATHSIG.
# Attend jusqu'à 5 s puis SIGKILL en dernier recours.
_kill_workers() {
    local i pid pids
    pids=$(ps 2>/dev/null | awk '/main\.lua/ && !/awk/ { print $1 }')
    [ -z "$pids" ] && return 0

    echo "custos: arrêt des workers (SIGTERM)..."
    for pid in $pids; do kill -TERM "$pid" 2>/dev/null || true; done

    i=0
    while [ $i -lt 5 ]; do
        sleep 1
        pids=$(ps 2>/dev/null | awk '/main\.lua/ && !/awk/ { print $1 }')
        [ -z "$pids" ] && return 0
        i=$((i + 1))
    done

    echo "custos: SIGKILL forcé..."
    for pid in $pids; do kill -KILL "$pid" 2>/dev/null || true; done
}

# ── Gestion des règles nftables ───────────────────────────────────────────────

# Nettoie les règles nftables appliquées par le service
_cleanup_nft_rules() {
    echo "custos: nettoyage des règles nftables..."

    # Supprime la table bridge si elle existe
    nft delete table bridge dns-filter-bridge 2>/dev/null || true

    echo "custos: règles nftables nettoyées"
}
