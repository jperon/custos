#!/bin/sh
# custos-update — Déploie les listes .bin pré-compilées de CustosVirginum
# depuis les releases GitHub du dépôt custos-lists.
#
# Remplace l'ancienne compilation locale (luajit updater.lua) : les .bin sont
# désormais construits par la CI de custos-lists et publiés en release, puis
# simplement téléchargés ici (curl + zstd), vérifiés (SHA256) et déployés.
#
# Usage : custos-update [full|lowmem] [tag]
#   profil : full (custom + Toulouse) ou lowmem (custom seul).
#            Défaut : env CUSTOS_LISTS_PROFILE, sinon uci
#            custos.main.lists_profile, sinon autodétection selon la RAM.
#   tag    : tag de release. Défaut : env CUSTOS_LISTS_TAG, sinon uci
#            custos.main.lists_tag, sinon « latest ».
#
# Dépendances : curl, zstd, tar, sha256sum.
set -eu

REPO="${CUSTOS_LISTS_REPO:-jperon/custos-lists}"
DEST="${CUSTOS_LISTS_DIR:-$(uci get custos.main.lists_dir 2>/dev/null || echo /etc/custos/lists)}"
PID_FILE=/var/run/custos.pid

# Seuil RAM (kB) au-delà duquel l'autodétection choisit « full ».
# 128 Mo : en dessous, on bascule en « lowmem » (custom seul, sans Toulouse),
# en cohérence avec le mode RAM faible du daemon (cf. config runtime.lowmem).
MEM_FULL_THRESHOLD_KB="${CUSTOS_LISTS_MEM_THRESHOLD_KB:-131072}"

# ── Résolution du profil ──────────────────────────────────────────
profile="${1:-}"
[ -z "$profile" ] && profile="${CUSTOS_LISTS_PROFILE:-}"
[ -z "$profile" ] && profile="$(uci get custos.main.lists_profile 2>/dev/null || true)"
if [ -z "$profile" ]; then
    mem_kb=$(awk '/^MemTotal:/ {print $2; exit}' /proc/meminfo 2>/dev/null || echo 0)
    if [ "${mem_kb:-0}" -ge "$MEM_FULL_THRESHOLD_KB" ]; then
        profile=full
    else
        profile=lowmem
    fi
    echo "custos-update: profil auto = $profile (RAM ${mem_kb} kB)" >&2
fi

case "$profile" in
    full|lowmem) ;;
    *) echo "custos-update: profil invalide : $profile (attendu : full|lowmem)" >&2; exit 1 ;;
esac

# ── Tag de release ────────────────────────────────────────────────
tag="${2:-}"
[ -z "$tag" ] && tag="${CUSTOS_LISTS_TAG:-}"
[ -z "$tag" ] && tag="$(uci get custos.main.lists_tag 2>/dev/null || true)"
tag="${tag:-latest}"

archive="custos-lists-${profile}.tar.zst"
base="https://github.com/${REPO}/releases/download/${tag}"

# ── Outils requis ─────────────────────────────────────────────────
for tool in curl zstd tar sha256sum; do
    command -v "$tool" >/dev/null 2>&1 || {
        echo "custos-update: outil requis introuvable : $tool" >&2; exit 1; }
done

tmp="$(mktemp -d "${TMPDIR:-/tmp}/custos-lists.XXXXXX")"
trap 'rm -rf "$tmp"' EXIT INT TERM

echo "custos-update: téléchargement de $archive (tag $tag)…" >&2
# --retry : les uplinks de routeurs (et le CDN d'assets GitHub) connaissent des
# échecs de connexion transitoires ; on retente plutôt que d'abandonner.
curl_dl() {
    curl --silent --location --fail \
        --retry 3 --retry-delay 2 --retry-all-errors \
        --connect-timeout 20 -o "$1" "$2"
}
curl_dl "$tmp/$archive"   "$base/$archive"
curl_dl "$tmp/SHA256SUMS" "$base/SHA256SUMS"

echo "custos-update: vérification SHA256…" >&2
( cd "$tmp" && grep " $archive\$" SHA256SUMS | sha256sum -c - >/dev/null )

echo "custos-update: extraction vers $DEST…" >&2
mkdir -p "$DEST" "$tmp/extract"
zstd -dc "$tmp/$archive" | tar -xf - -C "$tmp/extract"
# Synchronisation : on copie le contenu extrait par-dessus la destination.
cp -a "$tmp/extract/." "$DEST/"

# ── Rechargement à chaud du daemon ────────────────────────────────
if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
    kill -HUP "$(cat "$PID_FILE")" \
        && echo "custos-update: SIGHUP envoyé (pid $(cat "$PID_FILE"))." >&2
elif pgrep -f "luajit.*main" >/dev/null 2>&1; then
    pkill -HUP -f "luajit.*main" \
        && echo "custos-update: SIGHUP envoyé (pgrep)." >&2
fi

echo "custos-update: listes déployées ($profile, $tag) dans $DEST." >&2
