# Exemple de configuration classifier — copier en .env et adapter.
# Les variables réelles de l'environnement (docker -e / export) restent prioritaires.

# Clé API (repli accepté : OPENROUTER_API_KEY)
CLASSIFIER_API_KEY=sk-or-...

# Endpoint chat/completions (API OpenAI-compatible). Défaut : OpenRouter.
# Exemples :
#   OpenRouter : https://openrouter.ai/api/v1/chat/completions
#   OpenAI     : https://api.openai.com/v1/chat/completions
#   Groq       : https://api.groq.com/openai/v1/chat/completions
#   Local      : http://localhost:11434/v1/chat/completions   (Ollama)
CLASSIFIER_API_URL=https://openrouter.ai/api/v1/chat/completions

# Modèle(s) par défaut (surchargé par --model). Défaut : openrouter/free.
# Plusieurs modèles séparés par des virgules → round-robin : en cas d'erreur 429
# (rate limit), classifier bascule sur le modèle suivant plutôt que de réessayer
# le même. Exemple :
#   CLASSIFIER_MODEL=google/gemma-3-27b-it:free, meta-llama/llama-3.3-70b-instruct:free
CLASSIFIER_MODEL=openrouter/free
