# Logs
*.log

# Runtime output directory
tmp/*
!tmp/.gitkeep

# Temporary files
*.tmp
*.swp
*.swo
*~

# Editor files
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Build artifacts
*.o
*.so
*.a

# Test artifacts
.coverage
*.prof

# Local config overrides
config.local.moon

# Secrets file (production credentials)
cfg/secrets
cfg/esm

# VM disk images and cloud-init artifacts
*.qcow2
cidata.iso
meta-data
user-data
network-config
test-vm.qcow2
.vagrant/
.kilo/

# Downloaded base images
images/

# Backup files
*.bak
.aider*

# Lua files compiled from .moon sources (canonical output goes to lua/)
# src/ipparse/**/*.lua are hand-written and must remain tracked.
src/*.lua
src/auth/*.lua
src/filter/*.lua
src/parse/*.lua


idefix3.json
